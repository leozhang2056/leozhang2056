# Ignore sensitive directories
templates/
outputs/

# Privacy / personal narrative (local only; do not commit)
Interview question/
Interview Question/
Interview questions/
Interview Questions/
interview_question/
interview-question/
interview-questions/
kb/interview_qa/
memory/
transcripts/

# Python cache
__pycache__/
*.pyc
*.pyo

# Ignore IDE files
.idea/
*.iml

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore temporary files
*.tmp
*.temp
*.log

# Ignore local environment files
.env
.env.local

# LinkedIn cookies for JD fetch (never commit)
.linkedin_cookies

# Ignore build outputs
build/
dist/
node_modules/

# Ignore large binary files that shouldn't be in git
*.zip
*.tar.gz
*.rar

# memory/ is fully ignored above (session + layered memory; may contain personal context)
